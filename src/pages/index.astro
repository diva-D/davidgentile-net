---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="David Gentile">
  <div class="home-wrap">
    <section class="intro">
      <h1>Notes from the intelligence interface.</h1>
      <p>Short arguments and small, interactive artefacts about AI, structure, and the shape of work when the machines can actually act.</p>
      <p>One idea at a time. Published when it's useful, not when it's polished.</p>
    </section>

    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <span class="date">{fmt(post.data.date)}</span>
          <a class="title" href={`/${post.slug}`}>{post.data.title}</a>
          <div class="summary">{post.data.description}</div>
        </li>
      ))}
    </ul>
  </div>
</Base>
