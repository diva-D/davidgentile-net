---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
const { Content } = await post.render();

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const kicker = post.data.tags?.[0] ?? 'Note';
const artefactHeight = post.data.artefactHeight ?? 780;
---
<Base
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.heroImage}
  type="article"
  publishedTime={post.data.date}
>
  <article>
    {/* Narrow header strip — kicker + title + date */}
    <header class="post-head">
      <div class="post-kicker">{kicker}</div>
      <h1>{post.data.title}</h1>
      <div class="post-meta">{fmt(post.data.date)}</div>
    </header>

    {/* Wide artefact stage — hero */}
    {post.data.artefact && (
      <section class="post-artefact">
        <iframe
          src={post.data.artefact}
          height={artefactHeight}
          loading="eager"
          scrolling="no"
          title={`${post.data.title} — interactive`}
          data-artefact-iframe
        ></iframe>
        <div class="artefact-caption">
          <a href={post.data.artefact} target="_blank" rel="noopener">open the artefact full-screen →</a>
        </div>
      </section>
    )}

    {/* Narrow essay body */}
    <div class="post-body">
      <Content />
    </div>
  </article>

  {post.data.artefact && (
    <>
      <style is:global>
        iframe[data-artefact-iframe] {
          transition: height 0.45s cubic-bezier(0.4, 0, 0.2, 1);
          width: 100%; border: 0; display: block;
        }
      </style>
      <script is:inline>
        // Artefact <-> post-page contract over postMessage:
        //   { type: "artefact:height", height }       → resize iframe smoothly
        //   { type: "artefact:phase-change" }         → scroll iframe top into view
        (function () {
          const frame = document.querySelector("iframe[data-artefact-iframe]");
          if (!frame) return;

          window.addEventListener("message", (e) => {
            const msg = e.data;
            if (!msg || e.source !== frame.contentWindow) return;

            if (msg.type === "artefact:height" && typeof msg.height === "number") {
              frame.style.height = msg.height + "px";
              return;
            }

            if (msg.type === "artefact:phase-change") {
              // On phase change the new narration is at the TOP of the iframe,
              // but the reader may have scrolled down inside it. Nudge the page
              // so the iframe's top is at the top of the viewport (or just
              // below a small margin). Matters most on mobile.
              const rect = frame.getBoundingClientRect();
              const absoluteTop = window.scrollY + rect.top - 12;
              // Only scroll if the iframe top is not already visible near the top
              if (rect.top < 0 || rect.top > 80) {
                window.scrollTo({ top: absoluteTop, behavior: "smooth" });
              }
            }
          });
        })();
      </script>
    </>
  )}
</Base>
