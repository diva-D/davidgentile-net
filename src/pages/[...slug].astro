---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Base from '../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const kicker = post.data.tags?.[0] ?? 'Note';

// OG image alt text: prefer <slug>/hero.alt.txt (hero-specific) and fall
// back to <slug>/beat.alt.txt (written by dgnet-beat, describes the animation
// the hero is a frame of). Read at build time; undefined if neither exists.
const publicDir = fileURLToPath(new URL('../../public/images/', import.meta.url));
const heroAltPath = `${publicDir}${post.id}/hero.alt.txt`;
const beatAltPath = `${publicDir}${post.id}/beat.alt.txt`;
const ogImageAlt = existsSync(heroAltPath)
  ? readFileSync(heroAltPath, 'utf-8').trim()
  : existsSync(beatAltPath)
    ? readFileSync(beatAltPath, 'utf-8').trim()
    : undefined;
---
<Base
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.heroImage}
  ogImageAlt={ogImageAlt}
  type="article"
  publishedTime={post.data.date}
>
  <article>
    {/* Narrow header strip — kicker + title + date */}
    <header class="post-head">
      <div class="post-kicker">{kicker}</div>
      <h1>{post.data.title}</h1>
      <div class="post-meta">{fmt(post.data.date)}</div>
    </header>

    {/* Post body — MDX posts place <Artefact> components inline here */}
    <div class="post-body">
      <Content />
    </div>
  </article>
</Base>
